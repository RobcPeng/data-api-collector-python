# =============================================================================
# Data API Collector — AWS Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and update for your environment.
# =============================================================================

aws_region  = "us-east-1"
instance_type = "t3.medium"      # 2 vCPU, 4 GB — sufficient for default stack (~$30/mo)
volume_size   = 30               # GB — sufficient without OCR model caches

# For the full stack with Elasticsearch + OCR, use:
# instance_type = "t3.large"    # 2 vCPU, 8 GB (~$60/mo)
# volume_size   = 50

# SSH key pair (must already exist in your AWS account)
key_name = "my-key-pair"

# Restrict access to your IP (recommended)
# Find your IP: curl ifconfig.me
allowed_cidr_blocks = ["0.0.0.0/0"]  # CHANGE THIS to your IP/32 for security

# Optional: custom tags
tags = {
  Environment = "dev"
  Team        = "data-engineering"
}

# Optional: HTTPS with a domain name
# enable_https = true
# domain_name  = "data-api.example.com"
