# =============================================================================
# Data API Collector - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# Or run: ./start.sh to auto-generate strong secrets.
#
# IMPORTANT: Never commit .env to git. It contains secrets.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_SERVER=postgres
POSTGRES_USER=dataapi
POSTGRES_PASSWORD=dataapi123
POSTGRES_DB=data_collector
DATABASE_URL=postgresql+psycopg://dataapi:dataapi123@postgres:5432/data_collector
POSTGRES_PORT=5432
POSTGRES_PORT_EXTERNAL=15432

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_PORT_EXTERNAL=16379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# External access (for Databricks or other external consumers via nginx/SSL)
KAFKA_EXTERNAL_HOST=your-hostname.com
KAFKA_EXTERNAL_PORT=9093

# --- API ---
API_V1_STR=/api/v1
PROJECT_NAME="Data API Collector"
DEBUG=true

# --- Security ---
# CHANGE THIS: Generate a strong key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Neo4j ---
NEO4J_USER=neo4j
# CHANGE THIS: Generate a strong password
NEO4J_PASSWORD=your-neo4j-password
NEO4J_URI=bolt://data-api-neo4j:7687
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=10
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_DATABASE=neo4j

# --- Ollama (optional) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama

# --- Caddy ---
CADDY_HTTP_PORT=10800
CADDY_HTTPS_PORT=10443

# --- OCR Service ---
MODEL_TYPE=transformers

# --- SSL Certificates (for Postgres native SSL) ---
SSL_CERT_PATH=/etc/letsencrypt/live/your-hostname.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-hostname.com/privkey.pem
